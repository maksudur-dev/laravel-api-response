{
    "name": "maksudur-dev/laravel-api-response",
    "description": "A lightweight Laravel package to standardize API JSON responses.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maksudur Rahman",
            "email": "valiantmaksud@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Maksudur\\ApiResponse\\": "src/"
        },
        "files": [
            "src/Helpers/response.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maksudur\\ApiResponse\\ApiResponseServiceProvider"
            ],
            "aliases": {
                "ApiResponse": "Maksudur\\ApiResponse\\Facades\\ApiResponse"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
